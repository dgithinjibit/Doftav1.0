# API Configuration
VITE_API_URL=https://doftav1-0.onrender.com
VITE_WS_URL=wss://doftav1-0.onrender.com

# Blockchain Configuration
VITE_CHAIN_ID=137
VITE_ETHEREUM_RPC=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
VITE_POLYGON_RPC=https://polygon-rpc.com

# Smart Contract Addresses (Update after deployment)
VITE_WASTE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CARBO_NFT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_DOFTA_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
VITE_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_GOVERNANCE_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect Project ID
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Analytics (Optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Feature Flags
VITE_ENABLE_GOVERNANCE=true
VITE_ENABLE_CARBON_CREDITS=true
VITE_ENABLE_DEFI=true

# Environment
VITE_ENV=development